local posx, posy = 64, 64
local speed = 1.2

local mx = 64
local my = 64

function _init()
    poke(0x5f2d, 1)
end

function _update()
    if btn(0) then posx -= speed end
    if btn(1) then posx += speed end
    if btn(2) then posy -= speed end
    if btn(3) then posy += speed end
    mx = stat(32)
    my = stat(33)
end

function _draw()
    cls()
    rectfill(posx - 1, posy - 1, posx + 1, posy + 1, 7)
    spr(1, posx - 3, posy - 3)
    line(posx, posy, mx, my, 7)
    rect(4, 4, 124, 124, 12)
    spr(0, mx-4, my-4)
end
