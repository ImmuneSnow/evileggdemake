local posx, posy = 64, 64
local speed = 1.3
local velx, vely = 0, 0
local accelx, accely = 0, 0
local friction = 0.95

local mx = 64
local my = 64

local dashing = false

function _init()
    poke(0x5f2d, 1)
end

function _update()
    if btn(4) then
        if btn(0) then accelx -= 0.3 end
        if btn(1) then accelx += 0.3 end
        if btn(2) then accely -= 0.3 end
        if btn(3) then accely += 0.3 end
    else
        velx = 0
        vely = 0
        if btn(0) then velx -= speed end
        if btn(1) then velx += speed end
        if btn(2) then vely -= speed end
        if btn(3) then vely += speed end
    end
    
    velx += accelx
    vely += accely

    velx *= 0.95
    vely *= 0.95

    posx += velx
    posy += vely
    accelx = 0 -- reset the push
    accely = 0

    mx = stat(32)
    my = stat(33)
end

function _draw()
    cls()
    rectfill(posx - 1, posy - 1, posx + 1, posy + 1, 7)
    spr(1, posx, posy)
    line(posx, posy, mx, my, 7)
    spr(0, mx-4, my-4)
end
